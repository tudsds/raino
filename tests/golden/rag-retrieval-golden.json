{
  "description": "Test that RAG retrieval returns correct provenance for STM32F407 datasheet chunks",
  "queries": [
    {
      "query": "STM32F407 absolute maximum ratings",
      "expectedChunkType": "absolute_max_ratings",
      "expectedManufacturer": "STMicroelectronics",
      "expectedMpn": "STM32F407VGT6",
      "expectedDocumentType": "datasheet",
      "minScore": 0.5
    },
    {
      "query": "STM32F407 pin description PA0",
      "expectedChunkType": "pin_description",
      "expectedManufacturer": "STMicroelectronics",
      "expectedDocumentType": "datasheet",
      "minScore": 0.5
    },
    {
      "query": "STM32F407 errata USB host",
      "expectedChunkType": "errata_item",
      "expectedManufacturer": "STMicroelectronics",
      "expectedDocumentType": "errata",
      "minScore": 0.3
    },
    {
      "query": "ESP32-S3 boot configuration strapping pins",
      "expectedChunkType": "boot_configuration",
      "expectedManufacturer": "Espressif",
      "expectedDocumentType": "datasheet",
      "minScore": 0.5
    },
    {
      "query": "LM7805 thermal derating",
      "expectedChunkType": "power_requirements",
      "expectedManufacturer": "Texas Instruments",
      "expectedDocumentType": "datasheet",
      "minScore": 0.3
    }
  ],
  "missingDataTests": [
    {
      "query": "STM32F407 DDR4 interface specification",
      "shouldReturnEmpty": true,
      "reason": "STM32F407 does not have DDR4 interface"
    }
  ]
}
