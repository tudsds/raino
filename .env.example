# ── Raino Phase 2 Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in values.
# All values are placeholders — the app runs in degraded/fixture mode without them.

# ── Database (Prisma) ──────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma ORM.
# For Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Kimi K2.5 LLM Gateway ──────────────────────────────────────────────────
KIMI_API_KEY=
# Base URL for Kimi K2.5 API (OpenAI-compatible). Defaults to https://api.moonshot.cn/v1
KIMI_API_BASE_URL=https://api.moonshot.cn/v1

# ── Supabase (Auth, Postgres, Storage, pgvector) ────────────────────────────
# Supabase Storage Buckets:
# - reports: Generated reports and audit trails
# - artifacts: Design artifacts (KiCad projects, Gerber files)
# - uploads: User-uploaded documents (datasheets, specs)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub Actions (Worker Dispatch) ────────────────────────────────────────
GITHUB_ACTIONS_DISPATCH_TOKEN=
GITHUB_REPOSITORY_OWNER=
GITHUB_REPOSITORY_NAME=

# ── Vercel Deployment ───────────────────────────────────────────────────────
VERCEL_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email Notifications (Resend) ────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Supplier API Keys ───────────────────────────────────────────────────────
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
# Note: DigiKey uses 2-legged OAuth (client_credentials). No redirect URI needed.

MOUSER_API_KEY=

JLCPCB_APP_ID=
JLCPCB_ACCESS_KEY=
JLCPCB_SECRET_KEY=

# ── Embedding Provider ──────────────────────────────────────────────────────
# EMBEDDING_PROVIDER: "openai" (when OPENAI_API_KEY is set) or "mock" (default)
EMBEDDING_PROVIDER=mock
# OpenAI embedding model (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# ── OpenAI (Embeddings) ────────────────────────────────────────────────────
# Required when EMBEDDING_PROVIDER=openai. Uses text-embedding-3-small (1536 dims).
OPENAI_API_KEY=
# Optional: override base URL for OpenAI-compatible embedding endpoints
OPENAI_BASE_URL=

# ── KiCad CLI ───────────────────────────────────────────────────────────────
KICAD_CLI_PATH=
