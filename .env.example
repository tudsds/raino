# ── Raino Phase 2 Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in values.
# All values are placeholders — the app runs in degraded/fixture mode without them.

# ── Database (Prisma) ──────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma ORM.
# For Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Kimi K2.5 LLM Gateway ──────────────────────────────────────────────────
KIMI_API_KEY=
# Base URL for Kimi K2.5 API (OpenAI-compatible). Defaults to https://api.moonshot.cn/v1
KIMI_API_BASE_URL=

# ── Supabase (Auth, Postgres, Storage, pgvector) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ── GitHub Actions (Worker Dispatch) ────────────────────────────────────────
GITHUB_ACTIONS_DISPATCH_TOKEN=
GITHUB_REPOSITORY_OWNER=
GITHUB_REPOSITORY_NAME=

# ── Vercel Deployment ───────────────────────────────────────────────────────
VERCEL_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email Notifications (Resend) ────────────────────────────────────────────
RESEND_API_KEY=

# ── Supplier API Keys ───────────────────────────────────────────────────────
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_REDIRECT_URI=

MOUSER_API_KEY=

JLCPCB_APP_ID=
JLCPCB_ACCESS_KEY=
JLCPCB_SECRET_KEY=

# ── Embedding Provider ──────────────────────────────────────────────────────
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-hash-384

# ── KiCad CLI ───────────────────────────────────────────────────────────────
KICAD_CLI_PATH=
