{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@raino/ui": ["../../packages/ui/src"],
      "@raino/ui/diagrams": ["../../packages/ui/src/components/diagrams"],
      "@raino/core": ["../../packages/core/src"]
    },
    "allowJs": true,
    "incremental": true
  },
  "include": ["next-env.d.ts", "src/**/*", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
